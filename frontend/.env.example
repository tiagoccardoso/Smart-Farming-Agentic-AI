# Server-side AI providers. Never expose these in client components.
OPENAI_API_KEY=
GEMINI_API_KEY=

OPENAI_CHAT_MODEL=gpt-5-mini
OPENAI_COMPLEX_MODEL=gpt-5.5
OPENAI_WEB_SEARCH_MODEL=gpt-4.1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_MODEL=gemini-2.5-pro

# Existing Supabase settings used by server-side routes and admin AI logs.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL used to generate absolute Open Graph/social preview URLs.
NEXT_PUBLIC_SITE_URL=https://www.plantasa.com.br
